# Matrix Expire Bot — Configuration
# Copy to config.yaml and fill in your values

# Homeserver URL (without trailing slash)
homeserver: "https://matrix.example.com"

# Bot credentials (choose one method)
user_id: "@expire-bot:example.com"
password: "CHANGE_ME"
# access_token: "syt_..."

# ─── Retention ────────────────────────────────────────────────
# Default retention for new rooms (set on first join)
default_retention: "7d"

# Maximum retention period users can set
max_retention: "365d"

# ─── Timings ─────────────────────────────────────────────────
# How often to check for expired messages (seconds)
cleanup_interval: 60

# Sync poll timeout (ms) — lower = faster response to commands
sync_timeout: 10000

# Cooldown between commands per user (seconds)
command_cooldown: 5

# ─── Rate limits ─────────────────────────────────────────────
# Max redactions per cleanup cycle
max_redacts_per_run: 50

# Max API requests per minute (token bucket)
max_requests_per_minute: 60

# Max messages to scan per room per cycle
max_scan_per_room: 1000

# ─── Permissions ─────────────────────────────────────────────
# Minimum power level to configure the bot (used when admins: "all")
min_power_level: 50

# Who can manage the bot and invite it to rooms:
# "all" — anyone with power level >= min_power_level (default)
# list  — only matching users (supports glob patterns)
# When a whitelist is set:
#   - only matching users can run commands (set/off/clean)
#   - invites from non-matching users are rejected automatically
#   - power level check is skipped (whitelist = full trust)
admins: "all"
# admins:
#   - "@admin:example.com"          # exact user
#   - "@*:matrix.example.com"       # all users from this server

# Command prefix
command_prefix: "!expire"

# Max chars to read from message body (after prefix).
# Only enough for the command + args, rest is ignored.
cmd_read_limit: 24

# ─── Notifications ───────────────────────────────────────────
# Report deleted message count after scheduled cleanup (true/false)
notify_cleanup: false

# ─── Paths ───────────────────────────────────────────────────
# SQLite database path
database: "/data/expire-bot.db"

# Logging level (DEBUG, INFO, WARNING, ERROR)
log_level: "INFO"

# Store path for matrix-nio sync state
store_path: "/data/store"

# Bot avatar image (path inside container, mount from host)
# Supported formats: PNG, JPG, GIF, WebP, SVG
# avatar: "/data/avatar.png"
